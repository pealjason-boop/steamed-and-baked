# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.xml     text eol=lf
*.htaccess text eol=lf
.gitignore text eol=lf

# Binary files — do not modify line endings
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.svg     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
